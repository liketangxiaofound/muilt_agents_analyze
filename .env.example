# ============================================================
# mutli-agents 环境变量配置模板
# 使用方法: 复制本文件为 .env 并填入真实值
#           cp .env.example .env
# ============================================================

# ---- LLM 配置 (DeepSeek) ----
# DeepSeek API 密钥（必填）
DEEPSEEK_API_KEY=sk-your-api-key-here
# DeepSeek API 端点（默认值通常无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DeepSeek 模型 ID
DEEPSEEK_MODEL_ID=deepseek-chat

# ---- LLM 生成参数（可选） ----
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.8
LLM_TOP_P=0.9

# ---- 本地存储 ----
# 报告和数据的本地存储根目录（默认为当前目录下的 local_storage）
LOCAL_STORAGE_DIR=./local_storage

# ---- SMTP 邮件配置（用于自动发送报告） ----
# SMTP 服务器地址
SMTP_HOST=smtp.example.com
# SMTP 端口（587=STARTTLS, 465=SSL）
SMTP_PORT=587
# SMTP 登录用户名
SMTP_USERNAME=your-email@example.com
# SMTP 登录密码（Gmail 需使用应用专用密码）
SMTP_PASSWORD=your-app-password
# 发件人邮箱
SENDER_EMAIL=your-email@example.com

# ---- 设备型号列表（逗号分隔） ----
# 在此填入需要监控的 IoT 设备型号
DEVICE_MODELS=GW_GC1,GW_GC2
